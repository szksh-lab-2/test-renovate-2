{
  "extends": [
    'github>suzuki-shunsuke/renovate-config#3.1.0',
    'github>suzuki-shunsuke/renovate-config:nolimit#3.1.0',
    'github>aquaproj/aqua-renovate-config',
  ],
  "customManagers": [
    {
       "customType": "regex",
       "datasourceTemplate": "github-releases",
       "depNameTemplate": "oracle.com/sqlcl",
       "managerFilePatterns": [
          "/\\.?aqua\\.ya?ml$/"
       ],
       "matchStrings": [
          " +(?:version|'version'|\"version\") *: +(?<currentValue>[^'\" \\n]+) +# renovate: depName=oracle.com/sqlcl[ \\n]",
          " +(?:version|'version'|\"version\") *: +'(?<currentValue>[^'\" \\n]+)' +# renovate: depName=oracle.com/sqlcl[ \\n]",
          " +(?:version|'version'|\"version\") *: +\"(?<currentValue>[^'\" \\n]+)\" +# renovate: depName=oracle.com/sqlcl[ \\n]",
          " +(?:name|'name'|\"name\") *: +oracle.com/sqlcl@(?<currentValue>[^'\" \\n]+)",
          " +(?:name|'name'|\"name\") *: +'oracle.com/sqlcl@(?<currentValue>[^'\" \\n]+)'",
          " +(?:name|'name'|\"name\") *: +\"oracle.com/sqlcl@(?<currentValue>[^'\" \\n]+)\""
       ],
       "packageNameTemplate": "jasonlyle88/sqlcl-releases"
    }
  ]
}
